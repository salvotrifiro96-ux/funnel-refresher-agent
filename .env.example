# Backend keys owned by the SaaS operator (you).
# Used to call Claude (analysis + copy) and OpenAI (gpt-image-1 generation).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Optional gate to keep the Streamlit UI behind a password during private testing.
APP_PASSWORD=changeme

# Usage logging via Google Apps Script webhook (write to Google Sheet).
# Leave empty to disable — logging is fully optional.
USAGE_LOG_WEBHOOK_URL=
USAGE_LOG_WEBHOOK_SECRET=
